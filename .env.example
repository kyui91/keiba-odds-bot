# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# スクレイピング間隔（秒）
POLL_INTERVAL=60

# オッズ急変閾値（%）
THRESHOLD_LOW=15    # 低オッズ（1.0〜5.0倍）
THRESHOLD_MID=20    # 中オッズ（5.0〜20.0倍）
THRESHOLD_HIGH=25   # 高オッズ（20.0倍以上）

# 最小変動幅（絶対値） - これ以下の小さな変動は無視
MIN_ABSOLUTE_CHANGE=1.0

# 監視対象
WATCH_JRA=true
WATCH_NAR=false
